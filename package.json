{
  "name": "tabby-quick-scripts-chenlei",
  "version": "3.2.0",
  "description": "Display shortcut script buttons above the terminal. Clicking a button executes the preset commands sequentially.在终端上方显示快捷脚本按钮，点击即可按顺序执行预设命令",
  "keywords": [
    "tabby-plugin"
  ],
  "engines": {
    "tabby": ">=1.0.0"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "webpack --progress --color",
    "watch": "webpack --progress --color --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "readme中文.md",
    "readme中文.assets"
  ],
  "author": "chenlei",
  "license": "MIT",
  "devDependencies": {
    "@angular/animations": "^12.0.0",
    "@angular/common": "^12.0.0",
    "@angular/core": "^12.0.0",
    "@angular/forms": "^12.0.0",
    "@angular/platform-browser": "^12.0.0",
    "@ng-bootstrap/ng-bootstrap": "^2.2.0",
    "@types/webpack-env": "^1.16.0",
    "apply-loader": "^2.0.0",
    "css-loader": "^5.1.1",
    "sass": "^1.32.0",
    "pug": "^2.0.3",
    "pug-loader": "^2.4.0",
    "rxjs": "^7.3.0",
    "sass-loader": "^11.0.1",
    "style-loader": "^2.0.0",
    "tabby-core": "^1.0.156",
    "tabby-settings": "^1.0.156",
    "tabby-terminal": "^1.0.156",
    "ts-loader": "^9.2.6",
    "typescript": "^4.2.3",
    "webpack": "^5.24.4",
    "webpack-cli": "^4.5.0"
  }
}
